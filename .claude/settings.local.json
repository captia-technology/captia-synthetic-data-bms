{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip:*)",
      "Bash(ruff:*)",
      "Bash(pytest:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(task:*)",
      "Bash(make:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(curl:*)",
      "Bash(mosquitto_pub:*)",
      "Bash(mosquitto_sub:*)",
      "Bash(influx:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Read(.env)",
      "Read(.env.example)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  },
  "language": "spanish",
  "alwaysThinkingEnabled": true
}
