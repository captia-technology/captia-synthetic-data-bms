{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "MAX_MCP_OUTPUT_TOKENS": "50000"
  },
  "permissions": {
    "allow": [
      "Bash(uv:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip:*)",
      "Bash(ruff:*)",
      "Bash(pytest:*)",
      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(task:*)",
      "Bash(make:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(curl:*)",
      "Bash(mosquitto_pub:*)",
      "Bash(mosquitto_sub:*)",
      "Bash(influx:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Read(.env)",
      "Read(.env.example)",
      "Bash(python -c ' *)",
      "Bash(BMS_N_AULAS=2 BMS_PRODUCTION_ALIAS_ENABLED=true uv run python -c ' *)",
      "Bash(rm -f output/audit_mini.csv)",
      "Bash(BMS_PRODUCTION_ALIAS_ENABLED=true MQTT_HOST=localhost MQTT_PORT=1884 BMS_N_AULAS=3 timeout 60 uv run python -c ' *)",
      "Bash(BMS_PRODUCTION_ALIAS_ENABLED=true uv run python -c ' *)",
      "Bash(mv /tmp/audit_mqtt_scenario.yaml audit_mqtt_scenario.yaml)",
      "Bash(pkill -f grafana_demo_publisher)",
      "Bash(explorer \"http://localhost:3001/d/bms-overview/bms-overview\")",
      "Bash(explorer \"http://localhost:3001/d/bms-overview\")",
      "Bash(explorer \"http://localhost:3001/d/bms-iaq-d\")",
      "Bash(pkill -f grafana_demo)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)"
    ]
  },
  "language": "spanish",
  "alwaysThinkingEnabled": true
}
