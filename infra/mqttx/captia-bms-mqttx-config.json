  "scripts": [
    {
      "id": "script-decode-captia",
      "name": "decode-captia-payload",
      "createAt": "2026-05-10T00:00:00.000Z",
      "updateAt": "2026-05-10T00:00:00.000Z",
      "script": "// Decodifica payload CAPTIA: {value, ts_ns} -> human-readable\nfunction execute(value, msg) {\n  try {\n    const obj = typeof value === 'string' ? JSON.parse(value) : value;\n    const tsMs = Math.floor(obj.ts_ns / 1e6);\n    const date = new Date(tsMs).toISOString();\n    const variable = (msg.topic || '').split('/').pop();\n    const aula = (msg.topic || '').split('/')[4];\n    const formatted = {\n      aula,\n      variable,\n      value: typeof obj.value === 'number' ? Number(obj.value.toFixed(3)) : obj.value,\n      ts: date\n    };\n    return JSON.stringify(formatted, null, 2);\n  } catch (e) {\n    return value;\n  }\n}"
    },
    {
      "id": "script-publish-fake-fault",
      "name": "publish-fault-example",
      "createAt": "2026-05-10T00:00:00.000Z",
      "updateAt": "2026-05-10T00:00:00.000Z",
      "script": "// Genera un payload de avería para publicar manualmente\n// Topic sugerido: captia/dev/bms_classrooms/ies_simarro/AULA01/event/fault.sensor_drift\nfunction execute(value, msg) {\n  const payload = {\n    value: 1.0,\n    ts_ns: Date.now() * 1000000,\n    severity: 0.7,\n    fault_type: 'sensor_drift',\n    source: 'manual'\n  };\n  return JSON.stringify(payload);\n}"
    }
  ]
