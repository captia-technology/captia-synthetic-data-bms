# =============================================================================
# CAPTIA-SYNTHETIC-DATA-BMS — Environment variables
# Copia este archivo a .env y rellena valores reales (NUNCA commitear .env).
# =============================================================================

# === Compose ===
# Windows usa ';' como separador entre archivos compose.
# Linux/macOS usa ':'.
COMPOSE_FILE=compose/base.yaml;compose/observability.yaml;compose/generator.yaml;compose/data-plane-init.yaml
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Network ===
CAPTIA_NETWORK_NAME=captia-network

# === MQTT (Mosquitto 2.0.18) ===
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_PORT_HOST=1884
MQTT_WS_PORT_HOST=9002
# MQTT_USER=
# MQTT_PASSWORD=
MQTT_TLS=false
CAPTIA_TOPIC_PREFIX=captia
CAPTIA_ENV=dev
CAPTIA_TENANT=default
CAPTIA_SITE=ies_simarro
CAPTIA_MQTT_QOS=1

# === InfluxDB 2.7 ===
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_PORT_HOST=8087
INFLUXDB_ORG=captia
INFLUXDB_BUCKET=telemetry
# Generar con: openssl rand -hex 32
INFLUXDB_TOKEN=CHANGE_ME_USE_OPENSSL_RAND
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_USE_OPENSSL_RAND

# === Redis 7 ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === Grafana 11.4 ===
GRAFANA_PORT_HOST=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GF_LIVE_HA_ENGINE=redis
GF_LIVE_HA_REDIS_ADDRESS=redis:6379

# === Observability ===
PROMETHEUS_PORT_HOST=9090
LOKI_PORT_HOST=3100
LOKI_URL=http://loki:3100

# === BMS Generator ===
BMS_GENERATOR_HOST=0.0.0.0
BMS_GENERATOR_PORT=8120
BMS_GENERATOR_PORT_HOST=8120
BMS_HEALTH_PORT=8121
BMS_DOMAIN_ID=bms_classrooms
BMS_N_AULAS=10
BMS_SEED=42
BMS_DEFAULT_CONFIG=/app/config/projects/bms_v1_demo.yaml
BMS_OUTPUT_DIR=/app/output
BMS_BACKFILL_DEFAULT_DAYS=30
BMS_FAULTS_ENABLED=false
# Generar con: openssl rand -hex 32
BMS_API_TOKEN=CHANGE_ME_USE_OPENSSL_RAND
